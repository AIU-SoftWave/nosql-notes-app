title Deployment Architecture

node "Docker Host" {
  package "Frontend Container" {
    component "Next.js 16 (Port: 3001)" as FE
  }

  package "Backend Container" {
    component "NestJS 11 (Port: 5000)" as BE
  }

  package "Database Container" {
    database "MongoDB (Port: 27017)" as DB
  }

  package "Network" {
    component "notes-network" as Net
  }
}

package "Docker Compose" {
  component "docker-compose.yml" as Compose
}

Compose --> FE : "Build & Run"
Compose --> BE : "Build & Run"
Compose --> DB : "Pull & Run"
Compose --> Net : "Create Network"

FE --> Net : "Connect"
BE --> Net : "Connect"
DB --> Net : "Connect"

FE --> BE : "HTTP (3001→5000)"
BE --> DB : "MongoDB Protocol (5000→27017)"

@enduml

@startuml AuthenticationSequence
!theme plain

skinparam backgroundColor white
skinparam shadowing false
skinparam roundcorner 12

skinparam defaultFontName Inter
skinparam arrowColor #333
skinparam componentBorderColor #333
skinparam componentBackgroundColor white

title Authentication Flow (JWT)

actor User
participant "Frontend\n(Next.js)" as FE
participant "Security Layer\n(Helmet + Rate Limit)" as Security
participant "Backend\n(NestJS)" as BE
participant "AuthService" as Auth
participant "MongoDB" as DB

== Registration Flow ==
User -> FE : Enter username/password
FE -> Security : POST /api/auth/register
Security -> Security : Check rate limit (5/15min)
Security -> BE : Forward request
BE -> Auth : register(dto)
Auth -> DB : Find user by username
DB -->> Auth : null (not found)
Auth -> Auth : Hash password (bcrypt, 10 rounds)
Auth -> DB : Create user document
DB -->> Auth : User created
Auth -> Auth : Generate JWT (7-day expiry)
Auth -->> BE : { accessToken, user }
BE -->> Security : 201 Created
Security -->> FE : Response
FE -->> User : Success + Store JWT

== Login Flow ==
User -> FE : Enter credentials
FE -> Security : POST /api/auth/login
Security -> Security : Check rate limit (5/15min)
Security -> BE : Forward request
BE -> Auth : login(dto)
Auth -> DB : Find user by username
DB -->> Auth : User document
Auth -> Auth : Compare password (bcrypt)
Auth -> Auth : Generate JWT (sub: userId, username)
Auth -->> BE : { accessToken, user }
BE -->> Security : 200 OK
Security -->> FE : Response
FE -->> User : Success + Store JWT

== Protected Request Flow ==
User -> FE : Access protected route
FE -> Security : GET /api/notes\nAuthorization: Bearer <token>
Security -> Security : Check rate limit (100/15min)
Security -> BE : Forward with token
BE -> BE : JWT Guard validates token
BE -> BE : Extract user from payload
BE -> DB : Query with userId
DB -->> BE : User's data
BE -->> Security : Response
Security -->> FE : Response
FE -->> User : Display data

@enduml

