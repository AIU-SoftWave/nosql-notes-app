title Component Diagram with Database Indexes

left to right direction

package "Frontend (Next.js 16)" {
  component "Notes Page" as NP
  component "Note Detail" as ND
  component "Create / Edit Form" as CF
}

package "Security Layer" {
  component "Helmet" as HELMET
  component "Rate Limiter" as RATE
}

package "Backend (NestJS)" {
  component "Notes Controller" as NC
  component "Notes Service" as NS
  component "DTOs" as DTO
  component "Validation Pipes" as VP
  component "JWT Guard" as JWT
  component "Input Sanitization" as SANITIZE
}

package "MongoDB Layer" {
  component "Notes Collection" as COL
  component "Text Index" as TIDX
  component "Compound Index\n(userId+isPublic+createdAt)" as CIDX
  component "Tag Index\n(tags+isPublic+createdAt)" as TAGIDX
  component "Sparse Index\n(views>100)" as SPIDX
  component "User Index\n(username unique)" as UIDX
  component "Stats Aggregation" as PL
}

database "MongoDB Cluster" as DB

' Frontend → Security
NP --> HELMET
ND --> HELMET
CF --> HELMET

' Security Flow
HELMET --> RATE : Security Headers
RATE --> NC : Filtered Requests

' Backend Flow
NC --> JWT : Protected Routes
NC --> VP : validate & sanitize
VP --> SANITIZE : @Transform
SANITIZE --> DTO : clean data
DTO --> NS : business logic

' Backend → DB with Indexes
NS --> COL : insertOne()
NS --> TIDX : Text Search
NS --> CIDX : User Notes Query
NS --> TAGIDX : Tag Filter
NS --> SPIDX : Popular Notes
NS --> UIDX : User Lookup
NS --> PL : Aggregation

COL --> DB
TIDX --> DB
CIDX --> DB
TAGIDX --> DB
SPIDX --> DB
UIDX --> DB
PL --> DB

