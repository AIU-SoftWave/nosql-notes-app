@startuml Architecture
!theme plain
skinparam componentStyle uml2
skinparam shadowing false
skinparam backgroundColor white

title NoSQL Notes Application - Architecture

left to right direction

actor User

' =========================
' Frontend
' =========================
package "Frontend (Next.js)" {
    component "Notes Page" as NP
    component "Note Detail" as ND
    component "Stats Page" as SP
}

' =========================
' Backend
' =========================
package "Backend (NestJS)" {
    component "Notes Controller" as NC
    component "Notes Service" as NS
    component "Mongoose ODM" as ODM
}

' =========================
' Database (fixed)
' =========================
database "MongoDB" as DB
component "notes collection" as COL

' =========================
' User interactions
' =========================
User --> NP : View Notes
User --> ND : View Note
User --> SP : View Stats

' =========================
' API calls
' =========================
NP --> NC : GET /notes
ND --> NC : GET /notes/:id\n(+ $inc views)
SP --> NC : GET /notes/stats

' =========================
' Backend flow
' =========================
NC --> NS : Process request
NS --> ODM : Query / Aggregate
ODM --> COL : CRUD operations
COL --> DB : Storage layer

@enduml

@startuml Sequence
!theme plain
title Sequence Diagram - CRUD Operations

actor User
participant "Frontend" as FE
participant "Backend" as BE
participant "MongoDB" as DB

=== CREATE NOTE ===
User -> FE : Create note
FE -> BE : POST /api/notes\n{title, content, tags}
BE -> DB : insertOne()
DB -> BE : Document
BE -> FE : 201 Created
FE -> User : Success

=== READ NOTE ===
User -> FE : View note
FE -> BE : GET /api/notes/:id
BE -> DB : findByIdAndUpdate\n$inc: {views: 1}
DB -> BE : Note (views+1)
BE -> FE : 200 OK
FE -> User : Display

=== GET STATS ===
User -> FE : View stats
FE -> BE : GET /api/notes/stats
BE -> DB : aggregate([...])
DB -> BE : Stats
BE -> FE : Stats
FE -> User : Dashboard

@enduml

@startuml DataModel
!theme plain
title Data Model - Note Document

object Note {
    _id : ObjectId
    title : String
    content : String
    tags : String[]
    comments : Comment[]
    views : Number
    createdAt : Date
    updatedAt : Date
}

object Comment {
    content : String
    createdAt : Date
}

Note *-- Comment : embeds

@enduml

@startuml Components
!theme plain
title Component Interactions

package "Frontend" {
    component "React Components" as UI
    component "TanStack Query" as Q
    component "API Client" as API
}

package "Backend" {
    component "Controller" as Ctrl
    component "Service" as Svc
    component "Mongoose" as M
}

database "MongoDB" as DB

UI -> Q : useQuery/useMutation
Q -> API : fetch
API -> Ctrl : HTTP
Ctrl -> Svc : business logic
Svc -> M : find/update/aggregate
M -> DB : CRUD operations

@enduml