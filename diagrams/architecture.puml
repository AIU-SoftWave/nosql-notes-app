@startuml Architecture
package "Frontend (Next.js)" {
  [Notes Page]
  [Note Detail View]
  [Markdown Editor]
}

package "Backend (NestJS)" {
  [Notes Controller]
  [Notes Service]
  [Mongoose Model]
}

database "NoSQL (MongoDB)" {
  folder "notes_app" {
    [Notes Collection]
  }
}

[Notes Page] --> [Notes Controller] : REST API (GET)
[Notes Controller] --> [Notes Service]
[Notes Service] --> [Mongoose Model]
[Mongoose Model] --> [Notes Collection] : Query/Persist
@enduml
